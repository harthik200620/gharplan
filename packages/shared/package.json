{
  "name": "@gharplan/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared Plan/BOQ types, JSON Schema and constants for GharPlan.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plan.schema.json": "./plan.schema.json"
  },
  "files": ["src", "plan.schema.json"],
  "scripts": {
    "gen:schema": "cd ../../engine && python scripts/export_schema.py",
    "gen:types": "json-schema-to-typescript plan.schema.json -o src/plan.generated.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.0",
    "typescript": "^5.4.0"
  }
}
