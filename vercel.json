{
  "version": 2,
  "builds": [
    { "src": "web/package.json", "use": "@vercel/next" },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": ["engine/**", "fixtures/**", "docs/**"] }
    }
  ],
  "routes": [
    { "src": "/engine/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/web/$1" }
  ]
}
