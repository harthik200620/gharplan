# ============================================================================
# GharPlan — environment template. Copy to .env (root), /engine/.env, /web/.env.local
# as needed. Nothing here is secret; fill real values locally (never commit .env).
# ============================================================================

# ---- Engine (FastAPI compute core) ----
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
# Comma-separated allowed CORS origins for the web app
ENGINE_CORS_ORIGINS=http://localhost:3000
# Brahmasthan (CENTER) detection strategy: grid_3x3 (classical 1/9) | area_rect_10pct
GHARPLAN_BRAHMASTHAN=grid_3x3
# Override fixtures location (defaults to <repo>/fixtures)
# GHARPLAN_FIXTURES_DIR=
# v2 generative floor-plan endpoint (off by default)
FEATURE_GENERATOR=false

# ---- Web -> Engine ----
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (auth + Postgres + storage) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-side only; NEVER expose to the browser

# ---- Razorpay (billing) ----
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=                 # TODO(human): live secret
RAZORPAY_WEBHOOK_SECRET=             # TODO(human): webhook signing secret

# ---- Optional LLM helper (brief -> room list). App works fully without it. ----
LLM_PROVIDER=                        # gemini | deepseek | (empty disables)
LLM_API_KEY=
LLM_MODEL=
